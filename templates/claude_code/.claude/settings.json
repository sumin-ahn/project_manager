{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(echo *)",
      "Bash(pwd)",
      "Bash(diff *)",
      "Bash(jq *)",
      "Bash(mkdir *)",
      "Bash(mv *)",
      "Bash(cp *)",
      "Bash(chmod *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(py *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git mv *)",
      "Bash(git rm *)",
      "Bash(./.claude/run_tests_hook.sh)",
      "Bash(gh auth *)",
      "Bash(git config *)",
      "Bash(ssh -T git@github.com)",
      "Bash(git init *)",
      "Bash(ssh-keyscan -t ed25519 github.com)",
      "Bash(ssh-keygen -lf -)",
      "Bash(mkdir -p ~/.ssh)",
      "Bash(git ls-remote *)",
      "Bash(git remote *)",
      "Bash(git push *)"
    ],
    "deny": [
      "Bash(rm *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f *)"
    ]
  },
  "autoCompactEnabled": false,
  "env": {
    "DISABLE_AUTO_COMPACT": "1"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/run_tests_hook.sh",
            "timeout": 60,
            "statusMessage": "Running tests..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/ctx_stop_hook.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/ctx_stop_hook.sh",
            "timeout": 15
          }
        ]
      }
    ]
  },
  "_comment": "Claude Code 프로젝트 공통 settings (git tracked·멀티-유저 공유 안전·T-0202 portable-by-construction). 이 파일은 치환 토큰·절대경로 0 — 모든 머신/프로젝트에서 byte-identical 하게 동작하므로 import/update 가 경로를 재작성할 필요가 없다(pm_update 는 이 파일을 덮지 않음·인스턴스 소유). 네이티브 auto-compact 는 autoCompactEnabled:false + env DISABLE_AUTO_COMPACT 로 이중 비활성(hard-stop 단일 게이트·ADR-0038 D3). 훅 경로는 런타임 머신별 해소 ${CLAUDE_PROJECT_DIR} + 인터프리터는 래퍼(.sh)가 self-resolve(python3→python — PY 치환토큰 폐기·T-0202). statusLine 은 ${CLAUDE_PROJECT_DIR} 미지원이라 상대경로 래퍼(cwd=프로젝트루트면 동작·아니면 무표시 graceful·필요시 settings.local.json 절대경로 override). permissions.allow 는 보수적 기본값(python/python3/py 와일드카드가 PM 도구 호출 커버). 머신-특정 권한/오버라이드는 settings.local.json (gitignore) 으로 분리.",
  "statusLine": {
    "type": "command",
    "command": ".claude/ctx_statusline.sh",
    "padding": 0
  }
}
