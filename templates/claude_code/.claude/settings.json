{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(echo *)",
      "Bash(pwd)",
      "Bash(diff *)",
      "Bash(jq *)",
      "Bash(mkdir *)",
      "Bash(mv *)",
      "Bash(cp *)",
      "Bash(chmod *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash({{PY}} .project_manager/tools/board.py *)",
      "Bash({{PY}} .project_manager/tools/pm_bootstrap.py *)",
      "Bash({{PY}} .project_manager/tools/pm_handoff.py *)",
      "Bash({{PY}} .project_manager/tools/ticket_finish.py *)",
      "Bash(CLAUDE_SESSION_NAME=pm {{PY}} .project_manager/tools/board.py *)",
      "Bash(CLAUDE_SESSION_NAME=pm {{PY}} .project_manager/tools/pm_bootstrap.py *)",
      "Bash(CLAUDE_SESSION_NAME=pm {{PY}} .project_manager/tools/pm_handoff.py *)",
      "Bash(CLAUDE_SESSION_NAME=pm {{PY}} .project_manager/tools/ticket_finish.py *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git mv *)",
      "Bash(git rm *)",
      "Bash(./.claude/run_tests_hook.sh)",
      "Bash(gh auth *)",
      "Bash(git config *)",
      "Bash(ssh -T git@github.com)",
      "Bash(git init *)",
      "Bash(ssh-keyscan -t ed25519 github.com)",
      "Bash(ssh-keygen -lf -)",
      "Bash(mkdir -p ~/.ssh)",
      "Bash(git ls-remote *)",
      "Bash(git remote *)",
      "Bash(git push *)"
    ],
    "deny": [
      "Bash(rm *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f *)"
    ]
  },
  "autoCompactEnabled": false,
  "env": {
    "DISABLE_AUTO_COMPACT": "1"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/run_tests_hook.sh",
            "timeout": 60,
            "statusMessage": "Running tests..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "{{PY}} ${CLAUDE_PROJECT_DIR}/.claude/ctx_stop_hook.py",
            "timeout": 15
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{PY}} ${CLAUDE_PROJECT_DIR}/.claude/ctx_stop_hook.py",
            "timeout": 15
          }
        ]
      }
    ]
  },
  "_comment": "Claude Code 프로젝트 공통 settings (git tracked·멀티-유저 공유 안전). 네이티브 auto-compact 는 autoCompactEnabled:false + env DISABLE_AUTO_COMPACT 로 이중 비활성(hard-stop 단일 게이트·ADR-0038 D3 — 압축이 hard-stop 을 선점 못 하니 PreCompact 백스톱 불요·제거). 훅 경로는 런타임 머신별 해소 ${CLAUDE_PROJECT_DIR} 를 쓴다(절대경로 박제 금지 — clone-and-go·다른 PC 에서 재-import 불필요). statusLine 은 ${CLAUDE_PROJECT_DIR} 미지원이라 상대경로(cwd=프로젝트루트면 동작·아니면 무표시 graceful·필요시 settings.local.json 절대경로 override). {{PY}} 는 인터프리터명(python3/python)·import 치환. permissions.allow 는 보수적 기본값. 머신-특정 권한/오버라이드는 settings.local.json (gitignore) 으로 분리.",
  "statusLine": {
    "type": "command",
    "command": "{{PY}} .claude/ctx_statusline.py",
    "padding": 0
  }
}
